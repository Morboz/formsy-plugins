# Environment variables for Formsy Plugin

# Required: Your Formsy API key
FORMSY_API_KEY=your-api-key-here

# Optional: API base URL (defaults to https://api.formsy.ai)
FORMSY_BASE_URL=https://api.formsy.ai

# Optional: Project ID
FORMSY_PROJECT_ID=your-project-id

# Optional: Enable/disable plugin (defaults to true)
FORMSY_ENABLED=true
